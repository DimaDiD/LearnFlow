{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Seq": {
    "Url": "http://localhost:8081"
  },
  "Jwt": {
    "SecretKey": "your-super-secret-key-min-32-characters-long!!",
    "Issuer": "LearnFlow.Identity",
    "Audience": "LearnFlow"
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "courses-route": {
        "ClusterId": "courses-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/courses/{**catch-all}"
        }
      },
      "enrollments-route": {
        "ClusterId": "enrollments-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/enrollments/{**catch-all}"
        }
      },
      "progress-route": {
        "ClusterId": "progress-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/progress/{**catch-all}"
        }
      },
      "certificates-route": {
        "ClusterId": "certificates-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/certificates/{**catch-all}"
        }
      },
      "search-route": {
        "ClusterId": "search-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/search/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7141"
          }
        }
      },
      "courses-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7229"
          }
        }
      },
      "enrollments-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7064"
          }
        }
      },
      "progress-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7197"
          }
        }
      },
      "certificates-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7252"
          }
        }
      },
      "search-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7107"
          }
        }
      }
    }
  }
}